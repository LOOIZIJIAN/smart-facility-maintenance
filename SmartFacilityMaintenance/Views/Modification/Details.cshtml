@model SmartFacilityMaintenance.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Request Details";
}

<div class="module-banner mb-4">
    <h1 class="h3 mb-1">Request Details</h1>
    <p class="text-muted mb-0">Full details and activity history for this maintenance request.</p>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-4">
        <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
            <div>
                <h2 class="h5 mb-1">#@Model.Id — @Model.Title</h2>
                <span class="badge bg-light text-dark border me-1">Priority: @Model.Priority</span>
                <span class="badge @Model.Status.ToBadgeClass()">@Model.Status.ToDisplayName()</span>
            </div>
            <div class="text-muted small text-end">
                Created @Model.CreatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")<br />
                Updated @Model.UpdatedAt.ToLocalTime().ToString("dd MMM yyyy, HH:mm")
            </div>
        </div>

        <p class="mb-3">@Model.Description</p>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted small text-uppercase">Category</div>
                <div>@Model.Category?.Name</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small text-uppercase">Building</div>
                <div>@Model.Building?.Name</div>
            </div>
            <div class="col-md-4">
                <div class="text-muted small text-uppercase">Room / Location</div>
                <div>@Model.RoomLocation</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small text-uppercase">Reported By</div>
                <div>@(Model.ReportedBy?.FullName ?? "—")</div>
            </div>
            <div class="col-md-6">
                <div class="text-muted small text-uppercase">Assigned To</div>
                <div>@(Model.AssignedTo?.FullName ?? "Not assigned")</div>
            </div>
        </div>

        <hr />

        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Back</a>

            @if (Model.Status == RequestStatus.Submitted)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Request</a>
            }

            @if (Model.Status != RequestStatus.Completed && Model.Status != RequestStatus.Cancelled)
            {
                <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger">Cancel Request</a>
            }

            <a asp-action="ActivityLog" asp-route-id="@Model.Id" class="btn btn-outline-secondary">View Activity Log</a>
        </div>
    </div>
</div>

<h2 class="h5 mb-3">Recent Activity</h2>

@if (Model.ActivityLogs != null && Model.ActivityLogs.Any())
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Date / Time</th>
                            <th>Action</th>
                            <th>Old Status</th>
                            <th>New Status</th>
                            <th>Performed By</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.ActivityLogs.OrderByDescending(l => l.Timestamp))
                        {
                            <tr>
                                <td class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("dd MMM yyyy, HH:mm")</td>
                                <td>@log.Action</td>
                                <td>@(log.OldStatus.HasValue ? log.OldStatus.Value.ToDisplayName() : "—")</td>
                                <td>@(log.NewStatus.HasValue ? log.NewStatus.Value.ToDisplayName() : "—")</td>
                                <td>@(log.PerformedBy?.FullName ?? "—")</td>
                                <td class="small text-muted">@log.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body text-center text-muted py-4">No activity logs found for this request.</div>
    </div>
}
