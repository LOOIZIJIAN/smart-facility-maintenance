@model SmartFacilityMaintenance.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Request Details";
}

<h2>Request Details</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card mb-3">
    <div class="card-header">
        <strong>@Model.Title</strong>
    </div>

    <div class="card-body">
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Category:</strong> @Model.Category?.Name</p>
        <p><strong>Building:</strong> @Model.Building?.Name</p>
        <p><strong>Room / Location:</strong> @Model.RoomLocation</p>
        <p><strong>Priority:</strong> @Model.Priority</p>
        <p><strong>Status:</strong> @Model.Status</p>
        <p><strong>Reported By:</strong> @Model.ReportedBy?.FullName</p>
        <p><strong>Assigned To:</strong> @(Model.AssignedTo?.FullName ?? "Not assigned")</p>
        <p><strong>Created At:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</p>
        <p><strong>Updated At:</strong> @Model.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</p>
    </div>
</div>

<div class="mb-4">
    <a asp-action="Index" class="btn btn-secondary">Back</a>

    @if (Model.Status == SmartFacilityMaintenance.Models.RequestStatus.Submitted)
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Request</a>
    }

    @if (Model.Status != SmartFacilityMaintenance.Models.RequestStatus.Completed &&
         Model.Status != SmartFacilityMaintenance.Models.RequestStatus.Cancelled)
    {
        <a asp-action="Cancel" asp-route-id="@Model.Id" class="btn btn-danger">Cancel Request</a>
    }

    <a asp-action="ActivityLog" asp-route-id="@Model.Id" class="btn btn-info">View Activity Log</a>
</div>

<h3>Recent Activity Logs</h3>

@if (Model.ActivityLogs != null && Model.ActivityLogs.Any())
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Date / Time</th>
                <th>Action</th>
                <th>Old Status</th>
                <th>New Status</th>
                <th>Performed By</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.ActivityLogs.OrderByDescending(l => l.Timestamp))
            {
                <tr>
                    <td>@log.Timestamp.ToLocalTime().ToString("dd/MM/yyyy hh:mm tt")</td>
                    <td>@log.Action</td>
                    <td>@log.OldStatus</td>
                    <td>@log.NewStatus</td>
                    <td>@log.PerformedBy?.FullName</td>
                    <td>@log.Notes</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>No activity logs found for this request.</p>
}