@model SmartFacilityMaintenance.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Cancel Request";
}

<div class="module-banner mb-4">
    <h1 class="h3 mb-1">Cancel Maintenance Request</h1>
    <p class="text-muted mb-0">Cancel this request if the issue has already been resolved or is no longer needed.</p>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle me-1"></i>
            Are you sure you want to cancel this maintenance request? This action will be recorded in the activity log.
        </div>

        <div class="card shadow-sm mb-3">
            <div class="card-body p-4">
                <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
                    <div>
                        <h2 class="h5 mb-1">#@Model.Id — @Model.Title</h2>
                        <span class="badge bg-light text-dark border me-1">Priority: @Model.Priority</span>
                        <span class="badge @Model.Status.ToBadgeClass()">@Model.Status.ToDisplayName()</span>
                    </div>
                </div>

                <p class="mb-3">@Model.Description</p>

                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Category</div>
                        <div>@Model.Category?.Name</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Building</div>
                        <div>@Model.Building?.Name</div>
                    </div>
                    <div class="col-md-4">
                        <div class="text-muted small text-uppercase">Room / Location</div>
                        <div>@Model.RoomLocation</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="CancelConfirmed" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label for="cancellationReason" class="form-label">Reason for Cancellation</label>
                        <textarea name="cancellationReason" id="cancellationReason" class="form-control" rows="3"
                                  placeholder="Example: Issue has already been resolved."></textarea>
                    </div>

                    <button type="submit" class="btn btn-danger">Confirm Cancel Request</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back</a>
                </form>
            </div>
        </div>
    </div>
</div>
