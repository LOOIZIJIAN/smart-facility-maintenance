@model SmartFacilityMaintenance.Models.MaintenanceRequest

@{
    ViewData["Title"] = "Cancel Request";
}

<h2>Cancel Maintenance Request</h2>

<div class="alert alert-warning">
    Are you sure you want to cancel this maintenance request?
</div>

<div class="card mb-3">
    <div class="card-header">
        <strong>@Model.Title</strong>
    </div>

    <div class="card-body">
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Category:</strong> @Model.Category?.Name</p>
        <p><strong>Building:</strong> @Model.Building?.Name</p>
        <p><strong>Room / Location:</strong> @Model.RoomLocation</p>
        <p><strong>Priority:</strong> @Model.Priority</p>
        <p><strong>Status:</strong> @Model.Status</p>
    </div>
</div>

<form asp-action="CancelConfirmed" asp-route-id="@Model.Id" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label for="cancellationReason" class="form-label">Reason for Cancellation</label>
        <textarea name="cancellationReason" id="cancellationReason" class="form-control" rows="4"
                  placeholder="Example: Issue has already been resolved."></textarea>
    </div>

    <button type="submit" class="btn btn-danger">Confirm Cancel Request</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Back</a>
</form>