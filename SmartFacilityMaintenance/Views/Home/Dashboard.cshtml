@using Microsoft.AspNetCore.Identity
@using SmartFacilityMaintenance.Models
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    var user = await UserManager.GetUserAsync(User);
    var roleLabel = User.IsInRole(Roles.Admin) ? "Administrator"
        : User.IsInRole(Roles.Maintenance) ? "Maintenance"
        : User.IsInRole(Roles.Staff) ? "Staff" : "Student";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Welcome, @(user?.FullName ?? "User")</h1>
        <p class="text-muted mb-0">Signed in as <span class="badge bg-secondary">@roleLabel</span></p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="card stat-card border-start-primary h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Total Requests</div>
                <div class="display-6 fw-bold">@ViewBag.Total</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card border-start-warning h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Open</div>
                <div class="display-6 fw-bold">@ViewBag.Open</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card border-start-success h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Completed</div>
                <div class="display-6 fw-bold">@ViewBag.Completed</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card border-start-danger h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">High Priority Open</div>
                <div class="display-6 fw-bold">@ViewBag.HighPriority</div>
            </div>
        </div>
    </div>
</div>

<h2 class="h5 mb-3">Quick actions</h2>
<div class="row g-3">
    <div class="col-md-6 col-lg-3">
        <a asp-controller="Request" asp-action="Index" class="text-decoration-none">
            <div class="card quick-link h-100"><div class="card-body">
                <i class="bi bi-clipboard-plus fs-3 text-primary"></i>
                <div class="fw-semibold mt-2">Requests</div>
                <div class="text-muted small">Submit &amp; manage issues</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-controller="Tracking" asp-action="Index" class="text-decoration-none">
            <div class="card quick-link h-100"><div class="card-body">
                <i class="bi bi-clock-history fs-3 text-primary"></i>
                <div class="fw-semibold mt-2">Tracking</div>
                <div class="text-muted small">Follow request progress</div>
            </div></div>
        </a>
    </div>
    <div class="col-md-6 col-lg-3">
        <a asp-controller="Modification" asp-action="Index" class="text-decoration-none">
            <div class="card quick-link h-100"><div class="card-body">
                <i class="bi bi-pencil-square fs-3 text-primary"></i>
                <div class="fw-semibold mt-2">Modify</div>
                <div class="text-muted small">Edit, cancel &amp; logs</div>
            </div></div>
        </a>
    </div>
    @if (User.IsInRole(Roles.Admin) || User.IsInRole(Roles.Staff) || User.IsInRole(Roles.Maintenance))
    {
        <div class="col-md-6 col-lg-3">
            <a asp-controller="Reports" asp-action="Index" class="text-decoration-none">
                <div class="card quick-link h-100"><div class="card-body">
                    <i class="bi bi-bar-chart fs-3 text-primary"></i>
                    <div class="fw-semibold mt-2">Reports</div>
                    <div class="text-muted small">Analytics &amp; summaries</div>
                </div></div>
            </a>
        </div>
    }
</div>
