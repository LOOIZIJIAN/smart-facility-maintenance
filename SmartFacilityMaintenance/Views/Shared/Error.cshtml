@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error</h1>
<h2 class="h4 text-danger">An error occurred while processing your request.</h2>

@if (Model.ShowRequestId)
{
    <p class="mt-3"><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
}

<p class="mt-3">Please try again, or contact the system administrator if the problem persists.</p>
<a asp-controller="Home" asp-action="Index" class="btn btn-primary">Back to home</a>
