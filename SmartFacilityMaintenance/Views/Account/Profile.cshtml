@model SmartFacilityMaintenance.Models.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="h3 mb-4">My Profile</h1>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Profile" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" readonly />
                        <div class="form-text">Email address cannot be changed.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Department" class="form-label"></label>
                            <input asp-for="Department" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="StaffStudentId" class="form-label"></label>
                            <input asp-for="StaffStudentId" class="form-control" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a asp-action="ChangePassword" class="btn btn-outline-secondary">Change password</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
