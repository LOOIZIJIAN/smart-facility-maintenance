@model IEnumerable<SmartFacilityMaintenance.Models.MaintenanceRequest>
@{
    ViewData["Title"] = "Maintenance Requests";
}

<h1 class="h3 mb-4">Maintenance Requests</h1>

<div class="table-responsive">
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>#</th><th>Title</th><th>Category</th><th>Building</th>
                <th>Priority</th><th>Status</th><th>Reported</th>
            </tr>
        </thead>
        <tbody>
        @if (!Model.Any())
        {
            <tr><td colspan="7" class="text-center text-muted py-4">No requests yet.</td></tr>
        }
        else
        {
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.Id</td>
                    <td>@r.Title</td>
                    <td>@r.Category?.Name</td>
                    <td>@r.Building?.Name</td>
                    <td>@r.Priority</td>
                    <td><span class="badge bg-secondary">@r.Status</span></td>
                    <td>@r.CreatedAt.ToString("dd MMM yyyy")</td>
                </tr>
            }
        }
        </tbody>
    </table>
</div>
