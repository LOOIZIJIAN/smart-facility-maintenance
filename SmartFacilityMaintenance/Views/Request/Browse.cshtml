@model MaintenanceRequest
@{
    ViewData["Title"] = "Maintenance Requests";
    int total = ViewBag.Total;
    int position = ViewBag.Position;
    int? previousId = ViewBag.PreviousId;
    int? nextId = ViewBag.NextId;
    bool isTech = User.IsInRole(Roles.Maintenance);
    bool isStaffOrAdmin = User.IsInRole(Roles.Staff) || User.IsInRole(Roles.Admin);
}

<div class="module-banner mb-4">
    <h1 class="h3 mb-1">Maintenance Requests</h1>
    <p class="text-muted mb-0">
        @if (isTech)
        {
            <text>Review each submitted request and update its progress.</text>
        }
        else
        {
            <text>Review each submitted request and close it once resolved.</text>
        }
    </p>
</div>

@if (Model is null)
{
    <div class="card shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            No maintenance requests have been submitted yet.
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        @if (previousId is null)
        {
            <span class="btn btn-outline-secondary disabled"><i class="bi bi-arrow-left"></i> Previous</span>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-action="Index" asp-route-id="@previousId">
                <i class="bi bi-arrow-left"></i> Previous
            </a>
        }
        <span class="text-muted small">Request @position of @total</span>
        @if (nextId is null)
        {
            <span class="btn btn-outline-secondary disabled">Next <i class="bi bi-arrow-right"></i></span>
        }
        else
        {
            <a class="btn btn-outline-secondary" asp-action="Index" asp-route-id="@nextId">
                Next <i class="bi bi-arrow-right"></i>
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-4">
            <div class="d-flex flex-wrap justify-content-between align-items-start mb-3">
                <div>
                    <h2 class="h5 mb-1">#@Model.Id — @Model.Title</h2>
                    <span class="badge bg-light text-dark border me-1">
                        Priority: @Model.Priority
                    </span>
                    <span class="badge @Model.Status.ToBadgeClass()">@Model.Status.ToDisplayName()</span>
                </div>
                <div class="text-muted small text-end">
                    Submitted @Model.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                </div>
            </div>

            <p class="mb-3">@Model.Description</p>

            <div class="row g-3 mb-3">
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Category</div>
                    <div>@Model.Category?.Name</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Building</div>
                    <div>@Model.Building?.Name</div>
                </div>
                <div class="col-md-4">
                    <div class="text-muted small text-uppercase">Room / Location</div>
                    <div>@Model.RoomLocation</div>
                </div>
            </div>

            <div class="row g-3 mb-3">
                <div class="col-md-6">
                    <div class="text-muted small text-uppercase">Reported By (Student / Staff)</div>
                    <div>@(Model.ReportedBy?.FullName ?? "—")</div>
                    @if (isStaffOrAdmin)
                    {
                        <div class="small text-muted">
                            <i class="bi bi-telephone me-1"></i>@(string.IsNullOrWhiteSpace(Model.ReportedBy?.PhoneNumber) ? "No phone number on file" : Model.ReportedBy!.PhoneNumber)
                        </div>
                    }
                </div>
                <div class="col-md-6">
                    <div class="text-muted small text-uppercase">Assigned Maintenance Staff</div>
                    <div>@(Model.AssignedTo?.FullName ?? "Not yet assigned")</div>
                    @if (isStaffOrAdmin)
                    {
                        <div class="small text-muted">
                            <i class="bi bi-telephone me-1"></i>@(string.IsNullOrWhiteSpace(Model.AssignedTo?.PhoneNumber) ? "No phone number on file" : Model.AssignedTo!.PhoneNumber)
                        </div>
                    }
                </div>
            </div>

            @if (Model.Attachments.Any())
            {
                var imageExtensions = new[] { ".jpg", ".jpeg", ".png", ".gif" };
                var images = Model.Attachments.Where(a => imageExtensions.Contains(System.IO.Path.GetExtension(a.StoredFileName).ToLower())).ToList();
                var otherFiles = Model.Attachments.Except(images).ToList();

                <div class="mb-3">
                    <div class="text-muted small text-uppercase mb-2">Attachments</div>

                    @if (images.Any())
                    {
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            @foreach (var img in images)
                            {
                                <img src="~/uploads/@img.StoredFileName" alt="@img.FileName"
                                     class="rounded border"
                                     style="width:96px;height:96px;object-fit:cover;cursor:pointer;"
                                     onclick="showAttachmentImage('@Url.Content("~/uploads/" + img.StoredFileName)', '@img.FileName')"
                                     onerror="handleAttachmentImageError(this)" />
                            }
                        </div>
                    }

                    @if (otherFiles.Any())
                    {
                        <div class="d-flex flex-wrap gap-2">
                            @foreach (var a in otherFiles)
                            {
                                <a href="~/uploads/@a.StoredFileName" target="_blank" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-paperclip me-1"></i>@a.FileName
                                </a>
                            }
                        </div>
                    }
                </div>
            }

            <hr />

            <div class="d-flex flex-wrap gap-2">
                @if (isTech)
                {
                    <form asp-action="StartMission" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-warning" @(Model.Status != RequestStatus.Submitted ? "disabled" : null)>
                            <i class="bi bi-play-fill me-1"></i> Start Mission
                        </button>
                    </form>
                    <form asp-action="Complete" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-success"
                                @(Model.Status is RequestStatus.Completed or RequestStatus.Closed or RequestStatus.Cancelled ? "disabled" : null)>
                            <i class="bi bi-check-lg me-1"></i> Completed
                        </button>
                    </form>
                }
                @if (isStaffOrAdmin)
                {
                    <form asp-action="Close" asp-route-id="@Model.Id" method="post">
                        <button type="submit" class="btn btn-danger"
                                @(Model.Status != RequestStatus.Completed ? "disabled" : null)>
                            <i class="bi bi-x-circle me-1"></i> Close Maintenance Request
                        </button>
                    </form>
                    @if (Model.Status != RequestStatus.Completed && Model.Status != RequestStatus.Closed)
                    {
                        <div class="form-text w-100 mt-1">
                            A request can only be closed once maintenance has marked it as Completed.
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

<div class="modal fade" id="attachmentImageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title" id="attachmentImageModalLabel">Attachment</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center">
                <img id="attachmentImageModalImg" src="" alt="" class="img-fluid rounded" />
            </div>
            <div class="modal-footer">
                <a id="attachmentImageModalDownload" href="" target="_blank" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-download me-1"></i> Open Original
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showAttachmentImage(src, name) {
            document.getElementById('attachmentImageModalImg').src = src;
            document.getElementById('attachmentImageModalLabel').textContent = name;
            document.getElementById('attachmentImageModalDownload').href = src;
            new bootstrap.Modal(document.getElementById('attachmentImageModal')).show();
        }

        function handleAttachmentImageError(imgEl) {
            var placeholder = document.createElement('div');
            placeholder.className = 'rounded border bg-light text-muted small text-center d-flex align-items-center justify-content-center';
            placeholder.style.width = '96px';
            placeholder.style.height = '96px';
            placeholder.title = 'This file is missing on the server.';
            placeholder.innerHTML = '<i class="bi bi-image-fill fs-4"></i>';
            imgEl.replaceWith(placeholder);
        }
    </script>
}
